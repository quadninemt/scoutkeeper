{
    "name": "quadnine/scoutkeeper",
    "description": "Free, open-source membership management system for Scout organisations",
    "type": "project",
    "license": "AGPL-3.0-or-later",
    "authors": [
        {
            "name": "Kevin Azzopardi",
            "email": "kevin@quadnine.mt",
            "homepage": "https://quadnine.mt"
        }
    ],
    "require": {
        "php": ">=8.2",
        "nikic/fast-route": "^1.3",
        "phpmailer/phpmailer": "^6.9",
        "pragmarx/google2fa": "^8.0",
        "symfony/html-sanitizer": "^7.2",
        "twig/twig": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/src/",
            "App\\Modules\\": "app/modules/",
            "Updater\\": "updater/",
            "Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "platform": {
            "php": "8.2.0"
        }
    }
}
