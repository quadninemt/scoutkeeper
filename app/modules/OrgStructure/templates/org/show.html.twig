{% extends "layouts/admin.html.twig" %}

{% block title %}{{ node.name }}{% endblock %}

{% block body %}
<div class="container-fluid px-4 py-4">
    {# Node header #}
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h1 class="h3 mb-1">{{ node.name }}</h1>
            <span class="badge bg-secondary-subtle text-secondary-emphasis">{{ node.level_type_name }}</span>
            {% if node.short_name %}
            <span class="text-body-secondary ms-2">({{ node.short_name }})</span>
            {% endif %}
            {% if not node.is_active %}
            <span class="badge bg-warning-subtle text-warning-emphasis ms-2">{{ t('org.inactive') }}</span>
            {% endif %}
        </div>
        {% if has_permission('org_structure.write') %}
        <div class="d-flex gap-2">
            <a href="/admin/org/nodes/{{ node.id }}/edit" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-pencil me-1"></i>{{ t('common.edit') }}
            </a>
            <a href="/admin/org/nodes/create?parent_id={{ node.id }}" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-lg me-1"></i>{{ t('org.add_child') }}
            </a>
        </div>
        {% endif %}
    </div>

    <div class="row">
        <div class="col-lg-8">
            {# Description #}
            {% if node.description %}
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                    <p class="mb-0">{{ node.description }}</p>
                </div>
            </div>
            {% endif %}

            {# Age group (for sections) #}
            {% if node.age_group_min or node.age_group_max %}
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                    <h2 class="h6 mb-2">{{ t('org.age_group') }}</h2>
                    <p class="mb-0">{{ node.age_group_min|default('?') }} — {{ node.age_group_max|default('?') }} {{ t('org.years') }}</p>
                </div>
            </div>
            {% endif %}

            {# Children #}
            {% if children is not empty %}
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-transparent d-flex justify-content-between align-items-center">
                    <h2 class="h6 mb-0">{{ t('org.children') }} ({{ children|length }})</h2>
                </div>
                <div class="list-group list-group-flush">
                    {% for child in children %}
                    <a href="/admin/org/nodes/{{ child.id }}" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                        <span>
                            <i class="bi {{ child.is_leaf ? 'bi-people' : 'bi-folder' }} text-body-secondary me-2"></i>
                            {{ child.name }}
                        </span>
                        <span class="badge bg-secondary-subtle text-secondary-emphasis">{{ child.level_type_name }}</span>
                    </a>
                    {% endfor %}
                </div>
            </div>
            {% endif %}

            {# Teams #}
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-transparent d-flex justify-content-between align-items-center">
                    <h2 class="h6 mb-0">{{ t('org.teams') }} ({{ teams|length }})</h2>
                </div>
                {% if teams is empty %}
                <div class="card-body text-body-secondary small">{{ t('org.no_teams') }}</div>
                {% else %}
                <div class="list-group list-group-flush">
                    {% for team in teams %}
                    <div class="list-group-item d-flex justify-content-between align-items-center">
                        <span>
                            <i class="bi bi-people-fill text-body-secondary me-2"></i>
                            {{ team.name }}
                            {% if team.is_permanent %}
                            <span class="badge bg-secondary-subtle text-secondary-emphasis ms-1">{{ t('org.permanent') }}</span>
                            {% else %}
                            <span class="badge bg-info-subtle text-info-emphasis ms-1">{{ t('org.temporary') }}</span>
                            {% endif %}
                        </span>
                        {% if has_permission('org_structure.write') %}
                        <form method="post" action="/admin/org/teams/{{ team.id }}/delete"
                              onsubmit="return confirm('{{ t('org.delete_team_confirm') }}')">
                            {{ csrf_field() }}
                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                        {% endif %}
                    </div>
                    {% endfor %}
                </div>
                {% endif %}

                {# Add team form #}
                {% if has_permission('org_structure.write') %}
                <div class="card-footer bg-transparent">
                    <form method="post" action="/admin/org/nodes/{{ node.id }}/teams" class="row g-2 align-items-end">
                        {{ csrf_field() }}
                        <div class="col">
                            <input type="text" name="team_name" class="form-control form-control-sm"
                                   placeholder="{{ t('org.team_name') }}" required>
                        </div>
                        <div class="col-auto">
                            <select name="is_permanent" class="form-select form-select-sm">
                                <option value="1">{{ t('org.permanent') }}</option>
                                <option value="0">{{ t('org.temporary') }}</option>
                            </select>
                        </div>
                        <div class="col-auto">
                            <button type="submit" class="btn btn-sm btn-primary">{{ t('common.add') }}</button>
                        </div>
                    </form>
                </div>
                {% endif %}
            </div>
        </div>

        <div class="col-lg-4">
            {# Node info sidebar #}
            <div class="card border-0 shadow-sm">
                <div class="card-body small">
                    <dl class="mb-0">
                        <dt class="text-body-secondary">{{ t('org.level_type') }}</dt>
                        <dd>{{ node.level_type_name }}</dd>

                        <dt class="text-body-secondary">{{ t('common.status') }}</dt>
                        <dd>{{ node.is_active ? t('org.active') : t('org.inactive') }}</dd>

                        <dt class="text-body-secondary">{{ t('org.sort_order') }}</dt>
                        <dd>{{ node.sort_order }}</dd>

                        <dt class="text-body-secondary">{{ t('common.created') }}</dt>
                        <dd class="mb-0">{{ node.created_at|format_date('d M Y H:i') }}</dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
