<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{{ t('auth.reset_email_subject', {org: org_name}) }}</title>
</head>
<body style="font-family: Arial, Helvetica, sans-serif; color: #212529; margin: 0; padding: 24px; background-color: #f8f9fa;">
    <div style="max-width: 560px; margin: 0 auto; background: #ffffff; border-radius: 8px; padding: 32px; border: 1px solid #dee2e6;">
        <h2 style="margin-top: 0; font-size: 20px;">{{ org_name }}</h2>
        <p>{{ t('auth.reset_email_intro') }}</p>
        <p style="text-align: center; margin: 28px 0;">
            <a href="{{ reset_url }}" style="background-color: #5e35b1; color: #ffffff; text-decoration: none; padding: 12px 24px; border-radius: 6px; display: inline-block; font-weight: bold;">
                {{ t('auth.reset_password') }}
            </a>
        </p>
        <p style="font-size: 13px; color: #6c757d;">{{ t('auth.reset_email_link_help') }}</p>
        <p style="font-size: 13px; word-break: break-all;"><a href="{{ reset_url }}">{{ reset_url }}</a></p>
        <p style="font-size: 13px; color: #6c757d;">{{ t('auth.reset_email_expiry') }}</p>
        <p style="font-size: 13px; color: #6c757d;">{{ t('auth.reset_email_ignore') }}</p>
    </div>
</body>
</html>
