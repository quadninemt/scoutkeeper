{% extends "layouts/base.html.twig" %}

{% block layout %}{% endblock %}

{% block body_wrapper %}
{# --- Topbar --- #}
<nav class="topbar navbar navbar-expand fixed-top border-bottom bg-body mode-{{ view.mode|default('admin') }}">
    <div class="container-fluid">
        {# Left: hamburger + logo #}
        <div class="d-flex align-items-center">
            <button class="btn btn-link text-body p-1 me-2 d-lg-none" type="button"
                    data-bs-toggle="offcanvas" data-bs-target="#sidebarOffcanvas"
                    aria-label="Toggle navigation">
                <i class="bi bi-list fs-4"></i>
            </button>
            <button class="btn btn-link text-body p-1 me-2 d-none d-lg-inline-block sidebar-toggle"
                    type="button" aria-label="Toggle sidebar"
                    x-data x-on:click="$store.sidebar.toggle()">
                <i class="bi bi-list fs-4"></i>
            </button>
            <a href="/" class="navbar-brand mb-0 fw-semibold text-body text-decoration-none">
                {{ app_name|default('ScoutKeeper') }}
            </a>
            {% include "components/_view_switcher.html.twig" ignore missing %}
        </div>

        {# Centre: search (desktop only) #}
        {# No <form> wrapper: avoids Enter-key race with form submission. #}
        {# input[type=search] natively fires the 'search' event on Enter. #}
        <div class="d-none d-md-flex flex-grow-1 justify-content-center position-relative topbar-search" style="max-width: 400px; margin: 0 auto;">
            <div class="input-group input-group-sm w-100">
                <input type="search" name="search" class="form-control border-end-0"
                       placeholder="{{ t('search.topbar_placeholder') }}"
                       autocomplete="off"
                       hx-get="/search"
                       hx-trigger="keyup changed delay:300ms, search, keyup[key=='Enter']"
                       hx-target="#search-results"
                       hx-sync="this:replace">
                <button type="button" class="input-group-text bg-body border-start-0 topbar-search-btn"
                        aria-label="{{ t('search.topbar_placeholder') }}"
                        hx-get="/search"
                        hx-include="previous input"
                        hx-target="#search-results"><i class="bi bi-search"></i></button>
            </div>
            <div id="search-results" class="global-search-results"></div>
        </div>

        {# Right: utilities #}
        <div class="d-flex align-items-center gap-1">
            {# Language switcher #}
            <div class="dropdown">
                <button class="btn btn-link text-body p-1" data-bs-toggle="dropdown" aria-expanded="false"
                        title="{{ t('common.language')|default('Language') }}">
                    <i class="bi bi-globe2"></i>
                    <span class="d-none d-sm-inline ms-1 small">{{ app_lang|upper }}</span>
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                    {% for lang in available_languages() %}
                    <li>
                        <form method="POST" action="/language/switch" class="m-0">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token }}">
                            <input type="hidden" name="lang_code" value="{{ lang.code }}">
                            <input type="hidden" name="redirect_to" value="{{ current_uri }}">
                            <button type="button" onclick="this.closest('form').submit()" class="dropdown-item language-switch-item d-flex align-items-center {{ lang.code == app_lang ? 'active' : '' }}">
                                <span class="text-uppercase small me-2 text-body-secondary" style="min-width: 2rem;">{{ lang.code }}</span>
                                <span>{{ lang.native_name }}</span>
                                {% if lang.code == app_lang %}
                                <i class="bi bi-check2 ms-auto"></i>
                                {% endif %}
                            </button>
                        </form>
                    </li>
                    {% endfor %}
                </ul>
            </div>

            {# Pending acknowledgements (policies + must-ack notices) #}
            {% include "components/_pending_ack.html.twig" %}

            {# Theme toggle (desktop only) #}
            <button class="btn btn-link text-body p-1 d-none d-lg-inline-block" title="{{ t('theme.toggle') }}"
                    x-data x-on:click="$store.theme.toggle()">
                <i class="bi" x-data :class="$store.theme.icon"></i>
            </button>

            {# User menu #}
            <div class="dropdown">
                <button class="btn btn-link text-body p-1" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="bi bi-person-circle"></i>
                    <span class="d-none d-sm-inline ms-1 small">{{ user.email|default('') }}</span>
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                    <li><a class="dropdown-item" href="/account"><i class="bi bi-person me-2"></i>{{ t('user.menu.profile') }}</a></li>
                    <li><hr class="dropdown-divider"></li>
                    {# Theme toggle for mobile (inside user menu) #}
                    <li class="d-lg-none">
                        <button class="dropdown-item" x-data x-on:click="$store.theme.toggle()">
                            <i class="bi me-2" :class="$store.theme.icon"></i>{{ t('theme.toggle') }}
                        </button>
                    </li>
                    <li class="d-lg-none"><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item text-danger" href="/logout"><i class="bi bi-box-arrow-right me-2"></i>{{ t('user.menu.logout') }}</a></li>
                </ul>
            </div>
        </div>
    </div>
</nav>

{# --- Sidebar (desktop) --- #}
{#
    Pick the single active nav item: the one whose route is the longest prefix
    of the current URI (exact match or followed by `/`). This stops shorter
    parent routes (e.g. /members) from highlighting when the user is on a
    sibling detail page (e.g. /members/pending-changes).
#}
{% set active_route = '' %}
{% set active_group = null %}
{% for group_id, items in nav_items %}
    {% for item in items %}
        {% if (current_uri == item.route or current_uri starts with item.route ~ '/') and item.route|length > active_route|length %}
            {% set active_route = item.route %}
            {% set active_group = group_id %}
        {% endif %}
    {% endfor %}
{% endfor %}
<aside class="sidebar {{ nav_items is empty ? 'd-none' : 'd-none d-lg-block' }}" x-data :class="$store.sidebar.collapsed ? 'sidebar-collapsed' : ''">
    <nav class="sidebar-nav">
        {% for group_id, items in nav_items %}
        <div class="sidebar-group">
            {% if group_id starts with '_' %}
                {% for item in items %}
                <a href="{{ item.route }}" class="sidebar-link d-flex align-items-center px-3 py-2 text-decoration-none rounded-2 {{ item.route == active_route ? 'active' : '' }}">
                    <i class="bi {{ item.icon }} sidebar-icon"></i>
                    <span class="sidebar-label">{{ t(item.label) }}</span>
                    {% if item.badge %}
                    <span class="badge bg-primary rounded-pill ms-auto">{{ item.badge }}</span>
                    {% endif %}
                </a>
                {% endfor %}
            {% else %}
                {# Default all groups to open so all nav links are reachable without a toggle click.
                   Users can collapse groups manually via the Bootstrap collapse toggle. #}
                {% set is_open = true %}
                <button class="sidebar-group-toggle d-flex align-items-center w-100 text-uppercase small fw-semibold text-body-secondary px-3 py-2 border-0 bg-transparent"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#sidebar-group-{{ group_id }}"
                        aria-expanded="{{ is_open ? 'true' : 'false' }}"
                        aria-controls="sidebar-group-{{ group_id }}">
                    <span class="sidebar-label">{{ t('nav.group.' ~ group_id) }}</span>
                    <i class="bi bi-chevron-down ms-auto sidebar-group-chevron"></i>
                </button>
                <div class="collapse {{ is_open ? 'show' : '' }}" id="sidebar-group-{{ group_id }}">
                    {% for item in items %}
                    <a href="{{ item.route }}" class="sidebar-link d-flex align-items-center px-3 py-2 text-decoration-none rounded-2 {{ item.route == active_route ? 'active' : '' }}">
                        <i class="bi {{ item.icon }} sidebar-icon"></i>
                        <span class="sidebar-label">{{ t(item.label) }}</span>
                        {% if item.badge %}
                        <span class="badge bg-primary rounded-pill ms-auto">{{ item.badge }}</span>
                        {% endif %}
                    </a>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
        {% endfor %}
        <div class="sidebar-group mt-auto">
            <hr class="mx-3 my-1 opacity-25">
            <a href="https://quadninemt.github.io/scoutkeeper/" target="_blank" rel="noopener"
               class="sidebar-link d-flex align-items-center px-3 py-2 text-decoration-none rounded-2 text-body-secondary">
                <i class="bi bi-book sidebar-icon"></i>
                <span class="sidebar-label">{{ t('nav.documentation')|default('Documentation') }}</span>
                <i class="bi bi-box-arrow-up-right ms-auto sidebar-label opacity-50" style="font-size: 0.7rem;"></i>
            </a>
        </div>
    </nav>
</aside>

{# --- Sidebar (mobile offcanvas) --- #}
<div class="offcanvas offcanvas-start" tabindex="-1" id="sidebarOffcanvas">
    <div class="offcanvas-header border-bottom">
        <div class="flex-grow-1">
            <h5 class="offcanvas-title fw-semibold mb-0">{{ app_name|default('ScoutKeeper') }}</h5>
            {% if view is defined and (view.shows_mode_pills or view.active_scope) %}
            <div class="small text-body-secondary mt-1">
                <span class="badge bg-{{ view.mode == 'admin' ? 'primary' : 'success' }}-subtle text-{{ view.mode == 'admin' ? 'primary' : 'success' }}-emphasis">
                    <i class="bi {{ view.mode == 'admin' ? 'bi-shield-check' : 'bi-person' }} me-1"></i>{{ t('view.mode.' ~ view.mode) }}
                </span>
                {% if view.active_scope %}
                <span class="ms-1"><i class="bi bi-diagram-3 me-1"></i>{{ view.active_scope.leaf }}</span>
                {% elseif view.mode == 'admin' %}
                <span class="ms-1"><i class="bi bi-globe me-1"></i>{{ t('view.scope.all') }}</span>
                {% endif %}
            </div>
            {% endif %}
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="{{ t('common.close') }}"></button>
    </div>
    <div class="offcanvas-body p-0">
        {% include "components/_view_switcher_mobile.html.twig" ignore missing %}
        {# Search (mobile) — no <form> wrapper, same rationale as desktop. #}
        <div class="p-3 border-bottom">
            <div class="input-group input-group-sm">
                <span class="input-group-text bg-body border-end-0"><i class="bi bi-search"></i></span>
                <input type="search" name="search" class="form-control border-start-0"
                       placeholder="{{ t('search.topbar_placeholder') }}"
                       autocomplete="off"
                       hx-get="/search"
                       hx-trigger="keyup changed delay:300ms, search, keyup[key=='Enter']"
                       hx-target="#search-results-mobile"
                       hx-sync="this:replace">
            </div>
            <div id="search-results-mobile" class="mt-2"></div>
        </div>

        <nav class="py-2">
            {% for group_id, items in nav_items %}
            <div class="px-3 py-2">
                {% if group_id starts with '_' %}
                    {% for item in items %}
                    <a href="{{ item.route }}" class="d-flex align-items-center px-2 py-2 text-decoration-none rounded-2 {{ item.route == active_route ? 'active' : '' }}">
                        <i class="bi {{ item.icon }} me-2"></i>
                        <span>{{ t(item.label) }}</span>
                        {% if item.badge %}
                        <span class="badge bg-primary rounded-pill ms-auto">{{ item.badge }}</span>
                        {% endif %}
                    </a>
                    {% endfor %}
                {% else %}
                    {# Default all groups to open so all nav links are reachable without a toggle click.
                   Users can collapse groups manually via the Bootstrap collapse toggle. #}
                {% set is_open = true %}
                    <button class="sidebar-group-toggle d-flex align-items-center w-100 text-uppercase small fw-semibold text-body-secondary px-2 py-1 mb-1 border-0 bg-transparent"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#sidebar-group-{{ group_id }}-mobile"
                            aria-expanded="{{ is_open ? 'true' : 'false' }}"
                            aria-controls="sidebar-group-{{ group_id }}-mobile">
                        <span>{{ t('nav.group.' ~ group_id) }}</span>
                        <i class="bi bi-chevron-down ms-auto sidebar-group-chevron"></i>
                    </button>
                    <div class="collapse {{ is_open ? 'show' : '' }}" id="sidebar-group-{{ group_id }}-mobile">
                        {% for item in items %}
                        <a href="{{ item.route }}" class="d-flex align-items-center px-2 py-2 text-decoration-none rounded-2 {{ item.route == active_route ? 'active' : '' }}">
                            <i class="bi {{ item.icon }} me-2"></i>
                            <span>{{ t(item.label) }}</span>
                            {% if item.badge %}
                            <span class="badge bg-primary rounded-pill ms-auto">{{ item.badge }}</span>
                            {% endif %}
                        </a>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
            {% endfor %}
            <div class="px-3 py-1">
                <hr class="my-1 opacity-25">
                <a href="https://quadninemt.github.io/scoutkeeper/" target="_blank" rel="noopener"
                   class="d-flex align-items-center px-2 py-2 text-decoration-none rounded-2 text-body-secondary">
                    <i class="bi bi-book me-2"></i>
                    <span>{{ t('nav.documentation')|default('Documentation') }}</span>
                    <i class="bi bi-box-arrow-up-right ms-auto opacity-50" style="font-size: 0.7rem;"></i>
                </a>
            </div>
        </nav>
    </div>
</div>

{# --- aria-live announcements (mode/scope change). Consume the
     view_announce flash bucket BEFORE the main flash render so the
     main flash loop doesn't try to style them as an alert. #}
<div id="view-announce" class="visually-hidden" aria-live="polite" role="status">
    {% for msg in take_flash('view_announce') %}{{ msg }} {% endfor %}
</div>

{# --- Main content area --- #}
<div class="main-content">
    {# Breadcrumbs #}
    {% if breadcrumbs is not empty %}
    <nav aria-label="breadcrumb" class="px-4 pt-3">
        <ol class="breadcrumb mb-0 small">
            {% for crumb in breadcrumbs %}
            {% if loop.last %}
            <li class="breadcrumb-item active" aria-current="page">{{ crumb.label }}</li>
            {% else %}
            <li class="breadcrumb-item"><a href="{{ crumb.url }}">{{ crumb.label }}</a></li>
            {% endif %}
            {% endfor %}
        </ol>
    </nav>
    {% endif %}

    {# Flash messages #}
    {% set flashes = flash() %}
    {% if flashes is not empty %}
    <div class="px-4 pt-3">
        {% for type, messages in flashes %}
            {% for message in messages %}
            <div class="alert alert-{{ type == 'error' ? 'danger' : type }} alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="{{ t('common.close') }}"></button>
            </div>
            {% endfor %}
        {% endfor %}
    </div>
    {% endif %}

    <main id="main-content" class="p-4">
        {% block body %}{% endblock %}
    </main>

    {% include "components/_footer.html.twig" ignore missing %}
</div>

{# Session timeout modal #}
<div class="modal fade" id="sessionTimeoutModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">{{ t('session.timeout.title') }}</h5>
            </div>
            <div class="modal-body">
                <p>{{ t('session.timeout.message') }}</p>
                <a href="/login" class="btn btn-primary w-100">{{ t('session.timeout.login') }}</a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
