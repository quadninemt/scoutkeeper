# Second layer of protection for uploads and backups — the root .htaccess
# already denies /data/, but this holds even if those rules are lost
# (e.g. a bad root .htaccess edit). Never auto-updated.
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>
